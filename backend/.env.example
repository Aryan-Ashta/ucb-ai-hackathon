# Copy this file to .env and fill in real values. Never commit .env.
GITHUB_TOKEN=
ANTHROPIC_API_KEY=
TOKEN_COMPANY_API_KEY=
DEEPGRAM_API_KEY=
# ── Redis Cloud ─────────────────────────────────────────────────────────
# Create a free database at https://app.redislabs.com, then open it and click
# "Connect". Copy the values from there:
#   REDIS_HOST      public endpoint host (e.g. redis-12345.c1.us-east-1-2.ec2.redns.redis-cloud.com)
#   REDIS_PORT      endpoint port (e.g. 12345)
#   REDIS_USERNAME  database user — "default" unless you created an RBAC user
#   REDIS_PASSWORD  that user's password (the "user key")
#   REDIS_TLS       set to true if TLS is enabled on the database
# Leave REDIS_URL empty to use the fields below. Set it only to override with a
# full string, e.g. local redis://localhost:6379 or rediss://default:<pw>@host:port
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_TLS=false
SENTRY_DSN=
POKE_API_KEY=
# Fernet key for at-rest encryption of user GitHub access tokens in Redis.
# Generate locally with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Then paste the base64 string here. NEVER commit the real key.
TOKEN_ENCRYPTION_KEY=
# Override only for GitHub Enterprise. Default is fine for github.com.
GITHUB_API_BASE=https://api.github.com
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
