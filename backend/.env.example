# ── AI gateway (TokenRouter / OpenAI-compatible) ────────────────────────────
# Sign up at https://www.tokenrouter.com for an API key.
# TokenRouter serves /v1/chat/completions; base URL must include /v1.
TOKENROUTER_API_KEY=
TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1
TOKENROUTER_MODEL=minimax-m3

# Copy this file to .env and fill in real values. Never commit .env.
GITHUB_TOKEN=
TOKEN_COMPANY_API_KEY=
DEEPGRAM_API_KEY=
# ── Redis Cloud ─────────────────────────────────────────────────────────
# Create a free database at https://app.redislabs.com, then open it and click
# "Connect". Copy the values from there:
#   REDIS_HOST      public endpoint host (e.g. redis-12345.c1.us-east-1-2.ec2.redns.redis-cloud.com)
#   REDIS_PORT      endpoint port (e.g. 12345)
#   REDIS_USERNAME  database user — "default" unless you created an RBAC user
#   REDIS_PASSWORD  that user's password (the "user key")
#   REDIS_TLS       set to true if TLS is enabled on the database
# Leave REDIS_URL empty to use the fields below. Set it only to override with a
# full string, e.g. local redis://localhost:6379 or rediss://default:<pw>@host:port
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_TLS=false
SENTRY_DSN=
POKE_API_KEY=
# P1-B7: server-side calendar ID (was previously read from the request body,
# which was a horizontal-privilege primitive). One calendar ID for the demo;
# production would resolve per-user from a Poke OAuth flow + Redis.
POKE_USER_CALENDAR_ID=
# Fernet key for at-rest encryption of user GitHub access tokens in Redis.
# Generate locally with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Then paste the base64 string here. NEVER commit the real key.
TOKEN_ENCRYPTION_KEY=
# Override only for GitHub Enterprise. Default is fine for github.com.
GITHUB_API_BASE=https://api.github.com

# Voyage AI embeddings (vector store / RAG layer).
# Sign up at https://www.voyageai.com — free tier covers demo usage.
# Leave VOYAGE_API_KEY empty to fall back to a deterministic
# hash-based pseudo-embedding (good for tests + dev, useless for
# real semantic recall). Real recall requires a live API key.
VOYAGE_API_KEY=
VOYAGE_BASE_URL=https://api.voyageai.com
VOYAGE_MODEL=voyage-3
EMBEDDING_DIM=1024
